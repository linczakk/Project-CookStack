@using CookStack.Shared.ShoppingList.Dtos

@if (Lists.Count > 0)
{
    <div class="form-field">
        <label for="existing-shopping-list">
            Shopping list
        </label>

        <select id="existing-shopping-list"
                class="form-select cs-input"
                value="@SelectedListId"
                @onchange="OnChange">
            
            <option value="">Choose a shopping list</option>
        
            @foreach (var list in Lists)
            {
                <option value="@list.Id">
                    @list.Title
                </option>
            }
        </select>
    </div>
}
else
{
    <p class="empty-list-message">
        There are no existing shopping lists.
    </p>
}

@code {
    [Parameter] public List<ShoppingListsListDto> Lists { get; set; } = [];
    [Parameter] public int? SelectedListId { get; set; }
    [Parameter] public EventCallback<int?> SelectedListIdChanged { get; set; }


    private async Task OnChange(ChangeEventArgs e)
    {
        SelectedListId = int.TryParse(e.Value?.ToString(), out var id) ? id : null;
       
        await SelectedListIdChanged.InvokeAsync(SelectedListId);
    }

}
