@using CookStack.Client.Services
@using CookStack.Client.Services.ToastMessage
@using CookStack.Shared.Recipes.Dtos
@using CookStack.Shared.ShoppingList.Dtos

@implements IDisposable

@inject ShoppingListApiClient ShoppingListApi
@inject ToastService ToastService
@inject BrowserTitleService TitleService;
@inject KeyboardShortcutService KeyboardShortcutService;

@if(isOpen)
{
	<div class="modal-backdrop fade show"></div>

	<div class="modal fade show d-block" 
		  tabindex="-1" 
		  @onclick="Close">

		<div class="modal-dialog ingredients-modal-dialog" 
			 @onclick:stopPropagation="true">

			<div class="modal-content ingedients-modal-content">

				<EditForm Model="FormModel" 
						  OnValidSubmit="SaveAndClose">

					<DataAnnotationsValidator />

					<div class="modal-header ingredients-modal-header">
						<div>
							<h3>Add ingredients to shopping list</h3>

							<p>
								Choose where to add ingredients from
								<strong>@recipeTitle</strong>
							</p>
						</div>
					</div>


					<div class="modal-body ingredients-modal-body">

						<ValidationSummary class="validation-summary" />

						<section class="modal-card">
							<div class="modal-card-header">
								<h4>Destination</h4>
							</div>

							<ShoppingListModeSelector 
								@bind-IsNew="IsNew" 
								HasExistingLists="@ShoppingLists.Any()"/>

								@if(IsNew)
								{
									<div class="form-field">
										<label for="new-list-title">Title</label>

										<input id="new-list-title"
											   class="form-control cs-input"
											   placeholder="Shopping list title"
											   @bind="FormModel.Title"
											   @ref="titleInput" />
									</div>

									<div class="form-field">
										<label for="new-list-description">
											Description
										</label>
									</div>

									<InputTextArea id="new-list-description" 
												   class="form-control cs-input"
												   row="3"
												   placeholder="Optional description"
												   @bind-Value="FormModel.Description"/>

								}
								else
							{
								<ShoppingListSelector Lists="ShoppingLists"
													  @bind-SelectedListId="SelectedListId" />
							}

						</section>

						<section class="modal-card">
							<div class="modal-card-header">
								<h4>
									Ingredients
									<span class="selected-count">
										(@SelectedIngredientsCount selected)
									</span>
								</h4>
							</div>

							<IngredientSelector 
								Ingredients="Ingredients" 
								OnSelectionChanged="RefreshSelectedCount"/>
						</section>
					</div>

					<div class="modal-footer ingredients-modal-footer">
						<button type="submit" 
								class="btn btn-cs-primary btn-with-icon" 
								disabled="@isSaving">

							<span class="bi bi-cart-plus bi-invert"
								  aria-hidden="true"></span>

							@(isSaving ? "Saving..." : "Add ingredients")
						</button>

						<button type="button" 
								class="btn btn-cs-ghost" 
								@onclick="Close">
							Close
						</button>
					</div>
				</EditForm>
			</div>
		</div>
	</div>

}

@code {
	[Parameter]
	public EventCallback OnSaved { get; set; }

	[Parameter]
	public EventCallback OnClose { get; set; }


	private bool _isNew = true;

	public bool IsNew
	{
		get => _isNew;
		set
		{
			if (_isNew == value) return;

			_isNew = value;
			shouldFocus = true;
		}
	}
	private DotNetObjectReference<ShoppingListFromRecipeModal>? objectReference;

	private bool isOpen;
	private bool shouldFocus;
	private bool isSaving = false;

	private string recipeTitle = string.Empty;

	private ElementReference titleInput;

	private int? SelectedListId;

	private List<ShoppingListsListDto> ShoppingLists = [];
	private List<SelectableIngredientDto> Ingredients = [];

	private AddIngredientsToShoppingListDto FormModel = new();

	private int SelectedIngredientsCount =>
		Ingredients.Count(i => i.IsSelected);


	protected override void OnInitialized()
	{
		KeyboardShortcutService.OnEscapePressed += HandleEscape;
		KeyboardShortcutService.OnEnter += HandleEnter;
	}


	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (shouldFocus && IsNew)
		{
			shouldFocus = false;
			await titleInput.FocusAsync();
		}
	}

	public async Task Open(RecipeDetailsDto dto)
	{
		recipeTitle = dto.Title;

		FormModel = new AddIngredientsToShoppingListDto
		{
			Title = dto.Title,
			Description = $"Shopping list for: {dto.Title}"
		};

		Ingredients = dto.Ingredients
		.Select(i => new SelectableIngredientDto
			{
				Name = i.Name,
				Quantity = i.Quantity,
				Unit = i.Unit,
				IsSelected = true
			}).ToList();

		ShoppingLists = await ShoppingListApi.GetShoppingListsAsync();

		SelectedListId = null;
		_isNew = true;
		shouldFocus = true;
		isSaving = false;
		isOpen = true;

		KeyboardShortcutService.IsModalOpen = true;

		await TitleService.SetTitle($"Create shopping list from: {FormModel.Title}");
		StateHasChanged();
	}

	private void HandleEscape()
	{
		if (isOpen)
			_ = Close();
	}

	private async void HandleEnter()
	{
		await SaveAndClose();
	}

	private void RefreshSelectedCount()
	{
		StateHasChanged();
	}

	private async Task SaveAndClose()
	{
		if (isSaving)
			return;

		isSaving = true;

		try
		{
			var success = await Save();

			if (success)
				await Close();
		}
		finally
		{
			isSaving = false;
		}

	}

	private async Task<bool> Save()
	{
		if (!IsNew && SelectedListId == null)
		{
			ToastService.ShowError("Select a shopping list", 3);
			return false;
		}

		var selectedItems = Ingredients
			.Where(i => i.IsSelected)
			.Select(i => new ShoppingItemDto
			{
				Name = i.Name,
				Quantity = i.Quantity,
				Unit = i.Unit
			})
			.ToList();

		if(selectedItems.Count == 0)
		{
			ToastService.ShowError("Select at least one ingredient", 3);
			return false;
		}

		var request = new AddIngredientsToShoppingListDto
		{
			Title = IsNew ? FormModel.Title : null,
			Description = IsNew ? FormModel.Description : null,
			ExistingListId = IsNew ? null : SelectedListId,
			Items = selectedItems
		};

		var success = await ShoppingListApi.AddIngredientsAsync(request);

		if (!success)
			return false;


		ToastService.ShowSuccess("Ingredients added!", 3);
		await OnSaved.InvokeAsync();

		return true;
	}
	public async Task Close()
	{
		isOpen = false;
		isSaving = false;

		KeyboardShortcutService.IsModalOpen = false;

		StateHasChanged();
		await OnClose.InvokeAsync();
	}

	public void Dispose()
	{
		KeyboardShortcutService.OnEscapePressed -= HandleEscape;
		KeyboardShortcutService.OnEnter -= HandleEnter;
	}
}
