@using CookStack.Client.Components.Recipes
@using CookStack.Client.Constants
@using CookStack.Client.Services
@using CookStack.Shared.Recipes.Dtos

@page "/recipe-create"
@inject RecipeApiClient Api
@inject NavigationManager Nav
@inject BrowserTitleService TitleService;

<RecipeForm RecipeDto="dto" OnSubmit="Create" OnCancel="Cancel" SubmitText="Create recipe" />

@code{
	private CreateRecipeDto dto = new();

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		await TitleService.SetTitle("Create recipe");
	}

	private async Task Create()
	{
		await Api.CreateRecipeAsync(dto);
		Nav.NavigateTo(Routes.Recipes.RecipesMain);
	}

	private void Cancel()
	{
		Nav.NavigateTo(Routes.Recipes.RecipesMain);
	}
}