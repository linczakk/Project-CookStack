@using CookStack.Client.Components.Recipes
@using CookStack.Client.Constants
@using CookStack.Client.Services
@using CookStack.Shared.Recipes.Dtos

@page "/recipe-create"
@inject RecipeApiClient Api
@inject NavigationManager Nav
@inject BrowserTitleService TitleService;

<div class="page-top">
	<div class="page-header">
		<div>
			<h3>Create Recipe</h3>
			<p class="page-subtitle">Add a new recipe to CookStack.</p>
		</div>
	</div>
</div>

<RecipeForm RecipeDto="dto" OnSubmit="Create" OnCancel="Cancel" OnImageSelected="HandleImageSelected" SubmitText="Create recipe" />

@code{
	private CreateRecipeDto dto = new();

	private IBrowserFile? selectedImage;

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		await TitleService.SetTitle("Create recipe");
	}

	private async Task Create()
	{
		var recipeId = await Api.CreateRecipeAsync(dto);

		if (recipeId is null or <= 0)
			return;

		if(selectedImage is not null)
		{
			var imagePath = await Api.UploadRecipeImageAsync(recipeId.Value, selectedImage);

			if (imagePath is null)
				return;
		}

		GoToDetails(recipeId.Value);
	}

	private void GoToDetails(int id) => Nav.NavigateTo(string.Format(Routes.Recipes.RecipeDetails, id));

	private void HandleImageSelected(IBrowserFile? file)
	{
		selectedImage = file;
	}

	private void Cancel() => Nav.NavigateTo(Routes.Recipes.RecipesMain);
}