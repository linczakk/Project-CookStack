@using CookStack.Client.Components.ShoppingList
@using CookStack.Client.Constants
@using CookStack.Client.Enums
@using CookStack.Client.Models
@using CookStack.Client.Services

@implements IDisposable

@inject NavigationManager NavManager
@inject RecipeApiClient RecipeApi
@inject ShoppingListApiClient ShoppingListApi
@inject KeyboardShortcutService KeyboardShortcutService

<ShoppingListModal @ref="shoppingListModal" />

@if(isOpen)
{
	<div class="modal-backdrop fade show"></div>

	<div class="modal fade show d-block" tabindex="-1" @onclick="Close">
		<div class="modal-dialog global-search-dialog" @onclick:stopPropagation="true">
			<div class="modal-content global-search-content">
				<div class="modal-header search-input-container">
					<input class="form-control global-search-input cs-input"
						placeholder="Search everything..."
						@ref="titleInput"
						value="@searchTerm"
						@oninput="OnSearchInput" />

						@if(string.IsNullOrWhiteSpace(searchTerm))
						{
							<span class="search-shortcut">
								<kbd>Ctrl</kbd>
								<kbd>K</kbd>
							</span>
						}
				</div>
				<div class="modal-body global-search-body">
					@if(!string.IsNullOrWhiteSpace(searchTerm))
					{
						<div class="search-section">
							<h5 class="search-section-title">
								Recipes
							</h5>

							@if (result.Recipes.Any())
							{
								<ul class="search-result-list">

									@for (int i = 0; i < result.Recipes.Count; i++)
									{
										var recipe = result.Recipes[i];

										<li class="search-result-item @(selectedIndex == i ? "selected" : "")"
											@onclick="() => GoToRecipe(recipe.Id)">
											<span class="result-title">@recipe.Title</span>
										</li>
									}
								</ul>
							}
							else
							{
								<p class="empty-search-message">No recipes found</p>
							}
						</div>

						<hr />

						<div class="search-section">
							<h5 class="search-section-title">
								Shopping Lists
							</h5>

							@if (result.ShoppingLists.Any())
							{
								<ul class="search-result-list">

									@for (int i = 0; i < result.ShoppingLists.Count; i++)
									{
										var shoppingList = result.ShoppingLists[i];

										var globalIndex = result.Recipes.Count + i;

										<li class="search-result-item @(selectedIndex == globalIndex ? "selected" : "")"
											@onclick="() => GoToShoppingList(shoppingList.Id)">
											<span class="result-title">@shoppingList.Title</span>
										</li>
									}
								</ul>
							}
							else
							{
								<p class="empty-search-message">No shopping lists found</p>
							}
						</div>
					}
				</div>
			</div>
		</div>
	</div>
	
}

@code {
	private GlobalSearchResult result = new();
	private ShoppingListModal? shoppingListModal;

	private bool isOpen;
	private string searchTerm = "";
	private ElementReference titleInput;

	private int selectedIndex = -1;

	private int TotalResult =>
		result.Recipes.Count +
		result.ShoppingLists.Count;


	public async Task Open(string? initialSearchTerm = null)
	{
		searchTerm = initialSearchTerm ?? "";

		result = new();

		isOpen = true;

		KeyboardShortcutService.IsModalOpen = true;

		StateHasChanged();

		await Task.Yield();
		await titleInput.FocusAsync();

		if (!string.IsNullOrWhiteSpace(searchTerm))
			await PerformSearch();


	}

	protected override void OnInitialized()
	{
		KeyboardShortcutService.OnEnter += HandleEnter;
		KeyboardShortcutService.OnEscapePressed += HandleEscape;
		KeyboardShortcutService.OnArrowDown += MoveDown;
		KeyboardShortcutService.OnArrowUp += MoveUp;
		KeyboardShortcutService.OnMouseDown += ClearSelection;
	}

	private async Task OnSearchInput(ChangeEventArgs e)
	{
		searchTerm = e.Value?.ToString() ?? "";

		await PerformSearch();
	}

	private async Task PerformSearch()
	{
		if(string.IsNullOrWhiteSpace(searchTerm))
		{
			result = new();
			selectedIndex = -1;
			StateHasChanged();
			return;
		}

		var recipesTask = RecipeApi.GetRecipesAsync(searchTerm);
		var shoppingTask = ShoppingListApi.GetShoppingListsAsync(searchTerm);

		await Task.WhenAll(recipesTask, shoppingTask);

		result.Recipes = await recipesTask;
		result.ShoppingLists = await shoppingTask;

		selectedIndex = -1;
		StateHasChanged();
	}

	private void GoToRecipe(int id)
	{
		NavManager.NavigateTo(string.Format(Routes.Recipes.RecipeDetails, id));
		Close();
	}

	private async Task GoToShoppingList(int id)
	{
		Close();

		await Task.Yield();

		shoppingListModal?.Open(ShoppingListModalMode.View, id);
	}


	private async void HandleEnter()
	{
		if (!isOpen)
			return;

		if (selectedIndex == -1)
			return;

		if(selectedIndex < result.Recipes.Count)
		{
			var recipe = result.Recipes[selectedIndex];

			GoToRecipe(recipe.Id);
			return;
		}

		var shoppingIndex =
			selectedIndex - result.Recipes.Count;

		if(shoppingIndex < result.ShoppingLists.Count)
		{
			var shoppingList =
			result.ShoppingLists[shoppingIndex];

			await GoToShoppingList(shoppingList.Id);
		}
	}

	private void MoveDown()
	{
		if(!isOpen)
			return;

		if (selectedIndex < TotalResult - 1)
		{
			selectedIndex++;
			StateHasChanged();
		}
	}

	private void MoveUp()
	{
		if (!isOpen)
			return;

		if(selectedIndex > 0)
		{
			selectedIndex--;
			StateHasChanged();
		}
	}

	private void HandleEscape()
	{
		if (isOpen)
			Close();
	}

	public void Close()
	{
		isOpen = false;
		searchTerm = "";
		selectedIndex = -1;

		result = new();

		KeyboardShortcutService.IsModalOpen = false;

		StateHasChanged();
	}

	private void ClearSelection()
	{
		selectedIndex = -1;
		StateHasChanged();
	}

	public void Dispose()
	{
		KeyboardShortcutService.OnEnter -= HandleEnter;
		KeyboardShortcutService.OnEscapePressed -= HandleEscape;
		KeyboardShortcutService.OnArrowDown -= MoveDown;
		KeyboardShortcutService.OnArrowUp -= MoveUp;
		KeyboardShortcutService.OnMouseDown -= ClearSelection;
	}
}
