@using CookStack.Client.Components.Shared
@using CookStack.Client.Components.Sort
@using CookStack.Client.Enums
@using CookStack.Client.Models.Sort
@using CookStack.Client.Services
@using CookStack.Shared.ShoppingList.Dtos;

@implements IDisposable

@page "/shopping-lists"
@inject ShoppingListApiClient ShoppingListApi
@inject LoadingService LoadingService
@inject NavigationManager NavManager
@inject BrowserTitleService TitleService;
@inject KeyboardShortcutService KeyboardShortcutService
@inject SortStateService SortStateService

<ConfirmDialog @ref="confirmDialog"
	Title="Delete list"
	Message="Are you sure you want to delete this shopping list?"
	OnConfirm="ConfirmDelete"/>

<ShoppingListModal @ref="shoppingListModal" OnSaved="LoadShoppingLists" OnClose="SetTitleName" />


@if (shoppingLists != null)
{
	<div class="page-header">
		<div>
			<h3>Shopping Lists</h3>
			<p class="page-subtitle">Manage your shopping lists.</p>
		</div>

		<button class="btn btn-cs-primary" @onclick=AddShoppingList>
			+ Add shopping list
		</button>
	</div>

	<div class="page-toolbar">
		<input class="form-control cs-input"
			   placeholder="Search shopping lists..."
			   @bind="searchTerm"
			   @oninput="OnSearchChanged" />

		<SortDropdown TSortField="ShoppingListSortField"
					  SortOptions="sortOptions"
					  OnChanged="OnSortChanged" />
	</div>

	<hr />

	if(shoppingLists.Count > 0)
	{
		var displayedLists = GetDisplayedShoppingLists();
		var activeList = displayedLists.Where(sl => !sl.IsCompleted).ToList();
		var completedList = displayedLists.Where(sl => sl.IsCompleted).ToList();
		

		<section class="page-section">
			@if (activeList.Any())
			{
				<div class="section-title">
					<h4>
						Active shopping lists (@activeList.Count)
					</h4>
				</div>
				
			}

			<div class="shopping-list-grid">
				@for (int i = 0; i < activeList.Count(); i++)
				{
					var shoppingList = activeList.ElementAt(i);

					<div class="shopping-list-card @(selectedIndex == i ? "selected" : "")">
						<div class="shopping-list-card-body" @onclick="() => GoToDetails(shoppingList.Id)">
							<h5>@shoppingList.Title</h5>

							<p class="text-muted">
								Created: @shoppingList.CreatedAt.ToString("dd.MM.yyyy")
							</p>

							<p class="text-muted">
								<small>
									@shoppingList.CompletedItems / @shoppingList.TotalItems bought
								</small>
							</p>
						</div>
						<div class="shopping-list-card-actions">
							<button class="btn btn-cs-danger btn-sm" @onclick="() => AskDelete(shoppingList.Id)">
								Delete
							</button>
						</div>
					</div>
				}

			</div>
		</section>
		

		

		<section class="page-section">
			@if (activeList.Any() && completedList.Any())
			{
				if (completedList.Any())
				{
					<div class="section-title">
						<h4>
							Completed shopping lists (@completedList.Count)
						</h4>
					</div>
				}
			}

			<div class="shopping-list-grid">
				@for (int i = 0; i < completedList.Count(); i++)
				{
					var shoppingList = completedList.ElementAt(i);
					var globalIndex = activeList.Count() + i;

					<div class="shopping-list-card @(selectedIndex == globalIndex ? "selected" : "")">
						<div class="shopping-list-card-body" @onclick="() => GoToDetails(shoppingList.Id)">
							<h5>@shoppingList.Title</h5>

							<p class="text-muted">
								Created: @shoppingList.CreatedAt.ToString("dd.MM.yyyy");
							</p>
							<p class="text-muted">
								<span class="badge bg-success ms-2">Completed</span>
							</p>
						</div>
						<div class="shopping-list-card-actions">
							<button class="btn btn-cs-danger btn-sm" @onclick="() => AskDelete(shoppingList.Id)">
								Delete
							</button>
						</div>
					</div>
				}
			</div>
		</section>

		

	}
	else
	{
		if(!string.IsNullOrWhiteSpace(searchTerm))
		{
			<p>No results found for: <b>@searchTerm</b></p>
		}
		else
		{
			<p>There are currently no added shopping lists</p>
		}

	}

	
}


@code {

	private List<ShoppingListsListDto>? shoppingLists;

	private ConfirmDialog? confirmDialog;
	private ShoppingListModal? shoppingListModal;
	private int deleteId;

	private string searchTerm = "";

	private int selectedIndex = -1;

	private SortOptions<ShoppingListSortField> sortOptions =
		new()
			{
				Field = ShoppingListSortField.CreatedAt,
				Direction = SortDirection.Descending
			};


	protected override void OnInitialized()
	{
		sortOptions = SortStateService.ShoppingListSort;

		KeyboardShortcutService.OnEnter += HandleEnter;
		KeyboardShortcutService.OnArrowDown += MoveDown;
		KeyboardShortcutService.OnArrowUp += MoveUp;
		KeyboardShortcutService.OnMouseDown += ClearSelection;
	}

	protected override async Task OnInitializedAsync()
	{
		await LoadingService.RunWithLoading(async () =>
		{
			await LoadShoppingLists();

		}, "Loading shopping lists...");

	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if(firstRender)
			await SetTitleName();
	}

	private async Task OnSearchChanged(ChangeEventArgs e)
	{
		searchTerm = e.Value?.ToString() ?? "";
		await LoadShoppingLists();
	}

	private async Task LoadShoppingLists()
	{
		ClearSelection();

		shoppingLists = await ShoppingListApi.GetShoppingListsAsync(searchTerm);
		
		ApplySorting();
	}

	private void GoToDetails(int id)
	{
		shoppingListModal?.Open(ShoppingListModalMode.View, id);
	}

	private void AddShoppingList()
	{
		shoppingListModal?.Open(ShoppingListModalMode.Create);
	}

	private void AskDelete(int id)
	{
		deleteId = id;
		confirmDialog?.Show();
	}

	private async Task ConfirmDelete()
	{
		await DeleteShoppingList(deleteId);
	}

	private async Task SetTitleName()
	{
		await TitleService.SetTitle("Shopping lists");
	}

	private async Task DeleteShoppingList(int id)
	{
		if (shoppingLists == null)
			return;

		var shoppingList = shoppingLists.FirstOrDefault(s => s.Id == id);

		if (shoppingList == null)
			return;

		shoppingLists.Remove(shoppingList);

		try
		{
			await ShoppingListApi.DeleteShoppingListAsync(id);
		}
		catch (Exception ex)
		{
			shoppingLists.Add(shoppingList);
			Console.Error.WriteLine(ex);
		}
	}

	private List<ShoppingListsListDto> GetDisplayedShoppingLists()
	{
		if (shoppingLists == null)
			return[];

		return shoppingLists
			.Where(s => !s.IsCompleted)
			.Concat(shoppingLists.Where(s => s.IsCompleted))
			.ToList();
	}


	private Task OnSortChanged(SortOptions<ShoppingListSortField> newOptions)
	{
		SortStateService.ShoppingListSort = newOptions;
		sortOptions = newOptions;

		ApplySorting();

		return Task.CompletedTask;
	}


	private void ApplySorting()
	{
		if (shoppingLists == null)
			return;

		shoppingLists = SortShoppingList(shoppingLists);

		StateHasChanged();
	}

	private List<ShoppingListsListDto> SortShoppingList(List<ShoppingListsListDto> lists)
	{
		return sortOptions.Field switch
		{
			ShoppingListSortField.Title =>
				sortOptions.Direction == SortDirection.Ascending
					? lists.OrderBy(s => s.Title).ToList()
					: lists.OrderByDescending(s => s.Title).ToList(),

			ShoppingListSortField.CreatedAt =>
				sortOptions.Direction == SortDirection.Ascending
					? lists.OrderBy(s => s.CreatedAt).ToList()
					: lists.OrderByDescending(s => s.CreatedAt).ToList(),
			ShoppingListSortField.Progress =>
				sortOptions.Direction == SortDirection.Ascending
					? lists.OrderBy(GetProgress).ToList()
					: lists.OrderByDescending(GetProgress).ToList(),
			_ => lists
		};
	}

	private float GetProgress(ShoppingListsListDto list)
	{
		if (list.TotalItems == 0)
			return 0;

		return (float)list.CompletedItems / list.TotalItems;
	}

	private void MoveDown()
	{
		var displayedLists = GetDisplayedShoppingLists();

		if (KeyboardShortcutService.IsModalOpen)
			return;

		if (selectedIndex < displayedLists.Count - 1)
		{
			selectedIndex++;
			StateHasChanged();
		}
	}

	private void MoveUp()
	{
		if(selectedIndex > 0)
		{
			selectedIndex--;
			StateHasChanged();
		}
	}

	private void HandleEnter()
	{
		var displayedLists = GetDisplayedShoppingLists();

		if (selectedIndex < 0 || selectedIndex >= displayedLists.Count)
			return;

		GoToDetails(displayedLists[selectedIndex].Id);
	}

	private void ClearSelection()
	{
		selectedIndex = -1;
		StateHasChanged();
	}

	public void Dispose()
	{
		KeyboardShortcutService.OnEnter -= HandleEnter;
		KeyboardShortcutService.OnArrowDown -= MoveDown;
		KeyboardShortcutService.OnArrowUp -= MoveUp;
		KeyboardShortcutService.OnMouseDown -= ClearSelection;
	}
}
