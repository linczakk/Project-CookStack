@using CookStack.Client.Enums
@using CookStack.Shared.ShoppingList.Dtos
<div class="modal-header">
	<h2><b>@Model.Title</b></h2>
</div>

<div class="modal-body">
	<p>@Model.Description</p>
	<div class="shopping-list-container">
		<table class="table table-sm @(isDragging ? "drag-active" : "")"
			   @ondragover:preventDefault="true">
			@foreach (var item in Model.Items.Where(i => !i.IsChecked))
			{
				<tr @key="(item.Id, item.IsChecked)"
					@ondragenter="() => DragEnter(item)"
					@ondragover:preventDefault="true"
					@ondrop="() => Drop(item)"
					class="@(draggedItem == item ? "dragging" : "")
					@(dragOverItem == item ? "drag-over" : "")">
					<td draggable="true"
						@ondragstart="() => StartDrag(item)"
						@ondragend="ResetDragState"
						style="cursor: grab;">
						☰
					</td>
					<td>
						<input type="checkbox"
							   checked="@item.IsChecked"
							   @onchange="(e) => ToggleItem(item, (bool)e.Value!)" />
					</td>
					<td class="item-name">@item.Name</td>
					<td>@item.Quantity @item.Unit</td>
				</tr>
			}

			<tr class="drop-zone @(draggedItem?.IsChecked == true ? "active" : "")"
				@ondragover:preventDefault="true"
				@ondrop="() => DropToEnd(false)">
				<td colspan="4">
					<div class="drop-hint">
						Move to active
					</div>
				</td>
			</tr>

			@if (Model.Items.Any(i => i.IsChecked) && Model.Items.Any(i => !i.IsChecked) || draggedItem != null)
			{
				<tr>
					<td colspan="3"><hr /></td>
				</tr>
			}

			@foreach (var item in Model.Items.Where(i => i.IsChecked))
			{
				<tr @key="(item.Id, item.IsChecked)"
					@ondragenter="() => DragEnter(item)"
					@ondragover:preventDefault="true"
					@ondrop="() => Drop(item)"
					class="completed-list
					@(draggedItem == item ? "dragging" : "")
					@(dragOverItem == item ? "drag-over" : "")">
					<td draggable="true"
						@ondragstart="() => StartDrag(item)"
						@ondragend="ResetDragState"
						style="cursor: grab;">
						☰
					</td>
					<td>
						<input type="checkbox"
							   checked="@item.IsChecked"
							   @onchange="(e) => ToggleItem(item, (bool)e.Value!)" />
					</td>
					<td class="title text muted">@item.Name</td>
					<td>@item.Quantity @item.Unit</td>
				</tr>
			}

			<tr class="drop-zone @(draggedItem?.IsChecked == false ? "active" : "")"
				@ondragover:preventDefault="true"
				@ondrop="() => DropToEnd(true)">
				<td colspan="4">
					<div class="drop-hint">
						Move to completed
					</div>
				</td>
			</tr>

		</table>
	</div>

</div>
<div class="modal-footer">
	<button class="btn btn-primary" @onclick="() => OnEdit.InvokeAsync()">Update</button>
	<button type="button" class="btn btn-secondary" @onclick="() => OnClose.InvokeAsync()">Close</button>
</div>
@code {

	[Parameter] public ShoppingListBaseDto Model { get; set;} = new CreateShoppingListDto();
	[Parameter] public EventCallback OnEdit { get; set; }
	[Parameter] public EventCallback OnClose { get; set; }
	[Parameter] public EventCallback OnChanged { get; set; }

	private ShoppingItemDto? draggedItem;
	private ShoppingItemDto? dragOverItem;
	private bool isDragging;


	private async Task ToggleItem(ShoppingItemDto item, bool value)
	{
		item.IsChecked = value;

		if (item.IsChecked)
		{
			var maxCompleted = Model.Items
				.Where(i => i.IsChecked)
				.Select(i => i.Order)
				.DefaultIfEmpty(0)
				.Max();

			item.Order = maxCompleted + 1;
		}
		else
		{
			var maxActive = Model.Items
				.Where(i => !i.IsChecked)
				.Select(i => i.Order)
				.DefaultIfEmpty(0)
				.Max();

			item.Order = maxActive + 1;
		}

		SortItems();

		await OnChanged.InvokeAsync();
	}


	private void SortItems()
	{
		var sorted = Model.Items.
		OrderBy(i => i.IsChecked)
		.ThenBy(i => i.Order)
		.ToList();

		Model.Items.Clear();
		Model.Items.AddRange(sorted);
	}

	private void DragEnter(ShoppingItemDto item)
	{
		dragOverItem = item;
	}

	private void StartDrag(ShoppingItemDto item)
	{
		draggedItem = item;
		isDragging = true;
	}

	private async Task Drop(ShoppingItemDto target)
	{
		var index = Model.Items.IndexOf(target);
		await MoveItem(target.IsChecked, index);
	}

	private async Task DropToEnd(bool isChecked)
	{
		await MoveItem(isChecked);
	}

	private async Task MoveItem(bool isChecked, int? targetIndex = null)
	{
		if (draggedItem == null)
			return;

		draggedItem.IsChecked = isChecked;

		var items = Model.Items;

		items.Remove(draggedItem);

		if (targetIndex.HasValue)
			items.Insert(targetIndex.Value, draggedItem);
		else
			items.Add(draggedItem);

		Model.Items = Model.Items.ToList();

		RecalculateOrder();
		ResetDragState();

		await OnChanged.InvokeAsync();
	}


	private void RecalculateOrder()
	{
		for (int i = 0; i < Model.Items.Count; i++)
		{
			Model.Items[i].Order = i;
		}
	}

	private void ResetDragState()
	{
		draggedItem = null;
		dragOverItem = null;
		isDragging = false;
	}


}
