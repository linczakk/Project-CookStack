@using CookStack.Shared.ShoppingList.Dtos
<div class="modal-header">
	<div>
		<h3>@Model.Title</h3>

		@if (!string.IsNullOrWhiteSpace(Model.Description))
		{
			<p>@Model.Description</p>
		}
	</div>
</div>

@{
	var activeItems = Model.Items.Where(i => !i.IsChecked).ToList();
	var completedItems = Model.Items.Where(i => i.IsChecked).ToList();
}


<div class="modal-body">
	<div class="modal-card @(isDragging ? "drag-active" : "")">
		<div class="modal-card-header">
			<h4>Shopping Items</h4>
		</div>

		<section class="shopping-section">
			<div class="shopping-section-header">
				<h5>Active</h5>
				<span class="item-count">@activeItems.Count</span>
			</div>

			@if(activeItems.Count == 0)
			{
				<p class="empty-secion-message">No active items.</p>
			}
			else
			{
				<div class="modal-list">
					@foreach (var item in activeItems)
					{
						<div @key="(item.Id, item.IsChecked)"
							 @ondragenter="() => DragEnter(item)"
							 @ondragover:preventDefault="true"
							 @ondrop="() => Drop(item)"
							 class="modal-list-item
							@(draggedItem == item ? "dragging" : "")
							@(dragOverItem == item ? "drag-over" : "")">

							<div class="item-fields">
								<div class="drag-handle"
									 draggable="true"
									 title="Drag to reorder"
									 @ondragstart="() => StartDrag(item)"
									 @ondragend="ResetDragState">
									☰
								</div>
								<input class="item-checkbox cs-checkbox"
									   type="checkbox"
									   checked="@item.IsChecked"
									   aria-label="Mark @item.Name as completed"
									   @onchange="(e) => ToggleItem(item, (bool)e.Value!)" />
								
								<span class="item-name">@item.Name</span>

								<span class="item-amount">
									@item.Quantity @item.Unit
								</span>
							</div>
						</div>
					}
				</div>
			}

			@if (draggedItem?.IsChecked == true)
			{
				<div class="drop-zone"
					 @ondragover:preventDefault="true"
					 @ondrop="() => DropToEnd(false)">
					<span class="bi bi-cart-dash drop-zone-icon" aria-hidden="true"></span>
					<span>Move to active</span>
				</div>
			}
			
		</section>

		<section class="shopping-section">
			<div class="shopping-section-header">
				<h5>Completed</h5>
				<span class="item-count">@completedItems.Count</span>
			</div>

			@if(completedItems.Count == 0)
			{
				<p class="empty-section-message">No completed items.</p>
			}
			else
			{
				<div class="modal-list">
					@foreach (var item in Model.Items.Where(i => i.IsChecked))
					{
						<div @key="(item.Id, item.IsChecked)"
							 @ondragenter="() => DragEnter(item)"
							 @ondragover:preventDefault="true"
							 @ondrop="() => Drop(item)"
							 class="modal-list-item completed-item
							@(draggedItem == item ? "dragging" : "")
							@(dragOverItem == item ? "drag-over" : "")">

							<div class="item-fields">
								<div class="drag-handle"
									 draggable="true"
									 title="Drag to reorder"
									 @ondragstart="() => StartDrag(item)"
									 @ondragend="ResetDragState">
									☰
								</div>
								<input class="item-checkbox cs-checkbox"
									   type="checkbox"
									   checked="@item.IsChecked"
									   aria-label="Mark @item.Name as active"
									   @onchange="(e) => ToggleItem(item, (bool)e.Value!)" />

								<span class="item-name">@item.Name</span>

								<div class="item-amount">
									@item.Quantity @item.Unit
								</div>
							</div>
						</div>
					}
				</div>
			}
			

			@if (draggedItem?.IsChecked == false)
			{
				<div class="drop-zone"
					 @ondragover:preventDefault="true"
					 @ondrop="() => DropToEnd(true)">
					<span class="bi bi-cart-plus drop-zone-icon" aria-hidden="true"></span>
					<span>Move to completed</span>
				</div>
			}
		</section>
	</div>
</div>

<div class="modal-footer">
	<button class="btn btn-cs-primary" @onclick="() => OnEdit.InvokeAsync()">Update</button>
	<button type="button" class="btn btn-cs-ghost" @onclick="() => OnClose.InvokeAsync()">Close</button>
</div>
@code {

	[Parameter] public ShoppingListBaseDto Model { get; set;} = new CreateShoppingListDto();
	[Parameter] public EventCallback OnEdit { get; set; }
	[Parameter] public EventCallback OnClose { get; set; }
	[Parameter] public EventCallback OnChanged { get; set; }

	private ShoppingItemDto? draggedItem;
	private ShoppingItemDto? dragOverItem;
	private bool isDragging;


	private async Task ToggleItem(ShoppingItemDto item, bool value)
	{
		item.IsChecked = value;

		if (item.IsChecked)
		{
			var maxCompleted = Model.Items
				.Where(i => i.IsChecked)
				.Select(i => i.Order)
				.DefaultIfEmpty(0)
				.Max();

			item.Order = maxCompleted + 1;
		}
		else
		{
			var maxActive = Model.Items
				.Where(i => !i.IsChecked)
				.Select(i => i.Order)
				.DefaultIfEmpty(0)
				.Max();

			item.Order = maxActive + 1;
		}

		SortItems();

		await OnChanged.InvokeAsync();
	}


	private void SortItems()
	{
		var sorted = Model.Items.
		OrderBy(i => i.IsChecked)
		.ThenBy(i => i.Order)
		.ToList();

		Model.Items.Clear();
		Model.Items.AddRange(sorted);
	}

	private void DragEnter(ShoppingItemDto item)
	{
		dragOverItem = item;
	}

	private void StartDrag(ShoppingItemDto item)
	{
		draggedItem = item;
		isDragging = true;
	}

	private async Task Drop(ShoppingItemDto target)
	{
		var index = Model.Items.IndexOf(target);
		await MoveItem(target.IsChecked, index);
	}

	private async Task DropToEnd(bool isChecked)
	{
		await MoveItem(isChecked);
	}

	private async Task MoveItem(bool isChecked, int? targetIndex = null)
	{
		if (draggedItem == null)
			return;

		draggedItem.IsChecked = isChecked;

		var items = Model.Items;

		items.Remove(draggedItem);

		if (targetIndex.HasValue)
			items.Insert(targetIndex.Value, draggedItem);
		else
			items.Add(draggedItem);


		RecalculateOrder();
		ResetDragState();

		await OnChanged.InvokeAsync();
	}


	private void RecalculateOrder()
	{
		for (int i = 0; i < Model.Items.Count; i++)
		{
			Model.Items[i].Order = i;
		}
	}

	private void ResetDragState()
	{
		draggedItem = null;
		dragOverItem = null;
		isDragging = false;
	}


}
